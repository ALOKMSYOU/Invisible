--  FIREBASE HELPERS
-- ══════════════════════════════════════════════════════════════
local function fbReq(method, path, data)
    local req = (syn and syn.request)
             or (http and http.request)
             or request
             or http_request
    if not req then
        statusLbl.Text      = "✕ HTTP not supported"
        statusLbl.TextColor3= Color3.fromRGB(220, 60, 60)
        return nil
    end
    local ok, res = pcall(function()
        return req({
            Url     = FIREBASE .. path .. ".json",
            Method  = method,
            Headers = {["Content-Type"] = "application/json"},
            Body    = data and HttpService2:JSONEncode(data) or nil
        })
    end)
    if not ok or not res then return nil end
    local dok, decoded = pcall(HttpService2.JSONDecode, HttpService2, res.Body)
    return dok and decoded or nil
end

