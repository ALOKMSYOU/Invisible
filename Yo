local function _getTdata(txt)
    if _TUT[txt] then return _TUT[txt] end
    for k,v in pairs(_TUT) do
        local a = k:gsub(" : ON",""):gsub(" : OFF",""):gsub(": ON",""):gsub(": OFF","")
        local b = txt:gsub(" : ON",""):gsub(" : OFF",""):gsub(": ON",""):gsub(": OFF","")
        if a == b then return v end
    end
end

