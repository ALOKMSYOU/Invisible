local function startGuardianSystem(root)
    guardian_loop = runService.Heartbeat:Connect(function()
        if not ghost_active then return end
        
        -- ค้นหาวัตถุที่เรากำลังคุมอยู่ (เช็คจาก Network Ownership)
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.ReceiveAge == 0 and not obj:IsAncestorOf(character) then
                local dist = (obj.Position - root.Position).Magnitude
                if dist > NET_LIMIT then
                    -- ดึงกลับเข้าหารัศมีควบคุม
                    local pullDir = (root.Position - obj.Position).Unit
                    obj.Velocity = pullDir * 120 -- แรงดึงกลับ
                end
            end
        end
    end)
end

invisBtnFE.MouseButton1Click:Connect(function()
    if sound then sound:Play() end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart

    ghost_active = not ghost_active

    if ghost_active then
        -- 1. บันทึกและปรับโปร่งใส 0.5
        for _, v in pairs(char:GetDescendants()) do
            if (v:IsA("BasePart") or v:IsA("Decal")) and v.Name ~= "HumanoidRootPart" then
                appearance_data[v] = v.Transparency
                v.Transparency = 0.5
            end
        end

        -- 2. Loop ย้ายร่างไปซ่อน (FE)
        ghost_loop = runService.RenderStepped:Connect(function()
            if ghost_active and char:FindFirstChild("HumanoidRootPart") then
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CFrame = root.CFrame * CFrame.new(0, HIDE_OFFSET, 0)
                        part.CanCollide = false
                    end
                end
            end
        end)

        startGuardianSystem(root)
        
        invisBtnFE.Text = "Turn off (reset)"
        invisBtnFE.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    else
        -- ปิดระบบ
        if ghost_loop then ghost_loop:Disconnect() end
        if guardian_loop then guardian_loop:Disconnect() end
        
        -- คืนค่าเดิมเท่าที่ทำได้ (แนะนำให้ Reset ตัวละครจะดีที่สุด)
        for part, trans in pairs(appearance_data) do
            if part and part.Parent then part.Transparency = trans end
        end
        
        char.Humanoid.Health = 0 -- ต้อง Reset เพราะตัดข้อต่อ Joint ไปแล้วในสายตา Server
        ghost_active = false
        invisBtnFE.Text = "Turn on Invis"
