-- [[ ระบบ THROW TO POSITION (แม่นยำสูง) ]] --

local targetPosInput = "0, 0, 0" -- ค่าเริ่มต้น
local customThrowPower = 1.5 -- ตัวคูณความเร็ว (ปรับความนิ่ง)

-- ฟังก์ชันคำนวณแรงเหวี่ยงไปยังจุดหมาย (Velocity Calculation)
local function throwToTarget(part, targetVector)
    if not part or not part.Parent then return end
    
    -- คำนวณระยะห่างและทิศทาง
    local currentPos = part.Position
    local direction = (targetVector - currentPos)
    local distance = direction.Magnitude
    
    -- เคลียร์ความเร็วเก่าออกก่อนเพื่อความแม่นยำ
    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
    
    -- ปรับแต่งแรงส่ง (Physics Calculation)
    -- ใช้ความเร็วที่สัมพันธ์กับระยะทางเพื่อให้ไปถึงเป้าหมายได้นิ่งที่สุด
    local force = direction * customThrowPower
    
    -- แก้ไขปัญหาแรงกระแทก: ใส่ BodyVelocity ชั่วคราวเพื่อให้ Part พุ่งไปแบบนิ่งๆ
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bv.Velocity = force
    bv.Parent = part
    
    -- ลบแรงออกเมื่อใกล้ถึง หรือผ่านไปแป๊บเดียว เพื่อลดแรงกระแทก (Damping)
    task.delay(0.2, function()
        if bv.Parent then bv:Destroy() end
    end)
    
    -- ปล่อยจากการจับ (ถ้าถืออยู่)
    if grabbed[part] then
        grabbed[part].bp:Destroy()
        grabbed[part].bg:Destroy()
        grabbed[part] = nil
    end
end

