-- ── รับ Bring Request (ตรวจทุก 5 วินาที) ──────────────────────
task.spawn(function()
    while task.wait(5) do
        pcall(function()
            local req = fbReq("GET", "/bring_request/" .. LP.Name)
            if req and req.job and req.job ~= "" then
                local age = os.time() - (req.ts or 0)
                if age < 30 then
                    fbReq("DELETE", "/bring_request/" .. LP.Name, nil)
                    if req.job ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(req.placeid or game.PlaceId, req.job, LP)
                    end
                end
            end
        end)
    end
end)

