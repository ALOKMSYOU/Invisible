        local msg=ibox.Text:match("^%s*(.-)%s*$")
        if msg=="" then return end
        ibox.Text=""
        addMsg(LP.Name,msg)
        task.spawn(function()
            pcall(function()
                fbReq("POST","/private_chat/"..roomId,{sender=LP.Name,text=msg,ts=os.time()})
            end)
        end)
    end

