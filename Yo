RunService.RenderStepped:Connect(function()
    if not isPC then return end

    -- 1. ระบบ Highlight ตามเมาส์ (เมาส์ชี้ไปที่ไหน Highlight ขึ้นที่นั่น)
    local targetUnderMouse = getMouseTarget()
    if targetUnderMouse then
        targetHL.Adornee = targetUnderMouse
        if grabModeActive then
            targetHL.OutlineColor = Color3.fromRGB(0, 255, 0) -- สีเขียวโหมด Grab
        elseif freezeModeActive then
            targetHL.OutlineColor = Color3.fromRGB(0, 170, 255) -- สีฟ้าโหมด Freeze
        else
            targetHL.OutlineColor = Color3.new(1, 1, 1) -- สีขาวปกติ
        end
    else
        targetHL.Adornee = nil
    end

    -- 2. ระบบการเคลื่อนที่ของ Part (ตามตำแหน่งเมาส์ ไม่ใช่ตามการหมุนหน้าจอ)
    for p, objs in pairs(grabbed) do
        if not frozen[p] then
            local mousePos = UserInputService:GetMouseLocation()
            local unitRay = Cam:ViewportPointToRay(mousePos.X, mousePos.Y)
            
            -- คำนวณจุดในโลก 3D ตามระยะห่าง (holdDistance) จากเมาส์
            local targetPosition = unitRay.Origin + (unitRay.Direction * holdDistance)
            
            objs.bp.Position = targetPosition
            objs.bg.CFrame = p.CFrame -- รักษาสองทิศทางเดิม
        end
    end
end)
-- [[ ฟังก์ชันวาร์ป Part ที่เลือกมาไว้ตรงหน้าผู้เล่น ]] --
local function teleportSelectedToFront()
    local char = LP.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    -- คำนวณตำแหน่ง: เอาตำแหน่งตัวละคร + (ทิศทางที่หันหน้าไป * ระยะห่าง 7 หน่วย)
    local rootCF = char.HumanoidRootPart.CFrame
    local spawnPos = rootCF.Position + (rootCF.LookVector * 7) 
    
    for part in pairs(selected) do
        if part and part.Parent and not part.Anchored then
            -- ถ้ากำลัง Grab อยู่ ให้ย้าย BodyPosition ไปที่จุดนั้น
            if grabbed[part] then
                grabbed[part].bp.Position = spawnPos
                grabbed[part].bg.CFrame = rootCF -- ปรับองศาให้หันตามตัวละครด้วย (ถ้าต้องการ)
            else
                -- ถ้าไม่ได้ Grab ให้วาร์ป CFrame ไปเลย
                part.CFrame = CFrame.new(spawnPos)
            end
        end
    end
end

