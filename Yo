        while cg and cg.Parent do
            task.wait(2)
            pcall(function()
                local d=fbReq("GET","/private_chat/"..roomId)
                if not d then return end
                local s={}
                for id,m in pairs(d) do
                    if not cache2[id] then table.insert(s,{id=id,msg=m}) end
                end
                table.sort(s,function(a,b) return (a.msg.ts or 0)<(b.msg.ts or 0) end)
                for _,e in ipairs(s) do
                    cache2[e.id]=true
                    if e.msg.sender~=LP.Name then
                        addMsg(e.msg.sender or "?",e.msg.text or "")
                    end
                end
            end)
        end
    end)
