task.spawn(function()
    while task.wait(POLL_INT) do
        if pages.chat and pages.chat.Visible then
            local data = fbReq("GET", "/global")
            if data then
                local sorted = {}
                for id, msg in pairs(data) do
                    if not cache[id] then
                        table.insert(sorted, {id = id, msg = msg})
                    end
                end
                table.sort(sorted, function(a, b)
                    return (a.msg.ts or 0) < (b.msg.ts or 0)
                end)
                for _, entry in ipairs(sorted) do
                    cache[entry.id] = true
                    addChatMsg(entry.msg.u or "?", entry.msg.t or "", entry.msg.job, entry.msg.placeid)
                end
            end
        end
    end
end)

