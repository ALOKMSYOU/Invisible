    "เย็ด", "สาด", "ไอ้สัด", "แม่ง", "ชิบหาย", "อีดอก", "อีสัตว์"
}

local function containsBannedWord(text)
    local lower = text:lower()
    for _, word in ipairs(BANNED_WORDS) do
        if lower:find(word, 1, true) then return true, word end
    end
    return false, nil
end

local MUTE_DURATION = 30 * 60

local WARNING_MESSAGES = {
    [1] = "⚠️ Warning 1/3 — Stop! Don't use offensive language.",
    [2] = "⚠️ Warning 2/3 — Stop! Last warning before mute.",
    [3] = "🔇 Warning 3/3 — Alr, you're muted for 30 minutes."
}

local function isMuted(name)
    local data = fbReq("GET", "/warnings/" .. name)
    if not data then return false end
    if data.muted_until then
        if os.time() < data.muted_until then
            return true, data.muted_until
        else
            fbReq("DELETE", "/warnings/" .. name, nil)
            return false
        end
    end
    return false
end

local function getWarnings(name)
    local data = fbReq("GET", "/warnings/" .. name)
    if not data then return 0 end
    return data.count or 0
end

local function addWarning(name)
    local data = fbReq("GET", "/warnings/" .. name)
    local count = 0
    if data then count = data.count or 0 end
    count = count + 1
    if count >= 3 then
        fbReq("PUT", "/warnings/" .. name, {
            count = count, muted_until = os.time() + MUTE_DURATION, muted_by = "system"
        })
        return count, true
    else
        fbReq("PUT", "/warnings/" .. name, { count = count })
        return count, false
    end
end
local lastSentMsg = ""
local lastSentAt  = 0

local function setStatus(msg, col, resetSec)
    statusLbl.Text      = msg
    statusLbl.TextColor3= col
    if resetSec then
        task.delay(resetSec, function()
            statusLbl.Text      = "● Firebase connected"
            statusLbl.TextColor3= Color3.fromRGB(70, 200, 90)
        end)
    end
end

local function trySend()
    local msg = input.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end

    task.spawn(function()
        -- Check mute
        local muted, muteUntil = isMuted(LP.Name)
        if muted then
            local remaining = math.ceil((muteUntil - os.time()) / 60)
            setStatus("🔇 You are muted for " .. remaining .. " more min.", Color3.fromRGB(220, 60, 60), 4)
            input.Text = ""
            return
        end

        -- Check profanity
        local hasBad, _ = containsBannedWord(msg)
        if hasBad then
            local count, muted2 = addWarning(LP.Name)
            local warnMsg = WARNING_MESSAGES[math.min(count, 3)]
            setStatus(warnMsg, Color3.fromRGB(255, 80, 80), 5)
            input.Text = ""
            if muted2 then return end
            return
        end

        -- Anti-spam
        if msg == lastSentMsg then
            setStatus("⚠ Duplicate message!", Color3.fromRGB(255, 180, 0), 2)
            return
        end
        if (os.clock() - lastSentAt) < SPAM_COOL then
            setStatus("⚠ Wait " .. SPAM_COOL .. "s before sending again", Color3.fromRGB(255, 180, 0), 2)
            return
        end
        lastSentMsg = msg
        lastSentAt  = os.clock()
        input.Text  = ""

        fbReq("POST", "/global", {
            u   = LP.Name,
            t   = msg,
            job = game.JobId,
            ts  = os.time()
        })
    end)
end

