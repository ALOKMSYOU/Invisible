end)

-- ── Show warning count on login ─────────────────────────────
task.spawn(function()
    task.wait(3)
    pcall(function()
        local muted, muteUntil = isMuted(LP.Name)
        if muted then
            local remaining = math.ceil((muteUntil - os.time()) / 60)
            setStatus("🔇 You are muted for " .. remaining .. " min.", Color3.fromRGB(220, 60, 60))
        else
            local count = getWarnings(LP.Name)
            if count > 0 then
                setStatus("⚠️ You have " .. count .. "/3 warnings", Color3.fromRGB(255, 180, 0), 5)
            end
        end
    end)
end)

